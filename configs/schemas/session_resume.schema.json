{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "session_resume.schema.json",
  "title": "SessionResume",
  "description": "Session resume record capturing state at suspension and validation results on resume.",
  "type": "object",
  "required": ["session_id", "run_id", "project_id", "actor", "timestamp", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "run_id": { "type": "string" },
    "project_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "actor": { "$ref": "#/definitions/ActorRecord" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage_name": { "type": "string" },
    "policy_context": { "$ref": "#/definitions/PolicyContextRef" },
    "schema_version": { "type": "string", "default": "1.0.0" },
    "suspended_at": { "type": "string", "format": "date-time" },
    "resumed_at": { "type": "string", "format": "date-time" },
    "suspension_reason": { "type": "string" },
    "resume_validation_result": {
      "type": "object",
      "properties": {
        "is_valid": { "type": "boolean" },
        "failed_checks": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "checkpoint_ref": { "type": "string" },
    "workflow_state_snapshot_ref": { "type": "string" }
  },
  "definitions": {
    "ActorRecord": {
      "type": "object",
      "required": ["actor_id", "role"],
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" },
        "display_name": { "type": "string" },
        "delegation_chain": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PolicyContextRef": {
      "type": "object",
      "properties": {
        "policy_mode": { "type": "string" },
        "environment": { "type": "string" },
        "domain": { "type": "string" }
      }
    }
  }
}
