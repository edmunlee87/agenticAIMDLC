{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow_state.schema.json",
  "title": "WorkflowState",
  "description": "Workflow state machine record. Persisted after every material stage completion, review response, version selection, and block event.",
  "type": "object",
  "required": ["project_id", "run_id", "session_id", "current_stage", "stage_status", "actor", "timestamp", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "session_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "actor": { "$ref": "#/definitions/ActorRecord" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage_name": { "type": "string" },
    "policy_context": { "$ref": "#/definitions/PolicyContextRef" },
    "schema_version": { "type": "string", "default": "1.0.0" },
    "current_stage": { "type": "string" },
    "stage_status": {
      "type": "string",
      "enum": ["not_started", "running", "waiting_review", "waiting_selection", "completed", "failed", "blocked", "skipped"]
    },
    "completed_stages": {
      "type": "array",
      "items": { "$ref": "#/definitions/CompletedStageEntry" }
    },
    "pending_stages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pending_reviews": {
      "type": "array",
      "items": { "$ref": "#/definitions/PendingReviewRef" }
    },
    "blocking_reasons": {
      "type": "array",
      "items": { "$ref": "#/definitions/BlockingReason" }
    },
    "artifact_registry_reference": { "type": "string" },
    "approval_state": {
      "type": "object",
      "description": "Per-stage approval chain. Keys are stage names.",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/ApprovalRef" }
      }
    },
    "last_successful_transition": {
      "type": "object",
      "properties": {
        "from_stage": { "type": "string" },
        "to_stage": { "type": "string" },
        "transition_at": { "type": "string", "format": "date-time" },
        "actor": { "$ref": "#/definitions/ActorRecord" }
      }
    },
    "active_candidate_versions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "selected_versions": {
      "type": "object",
      "description": "stage_name -> selected candidate_version_id",
      "additionalProperties": { "type": "string" }
    },
    "governance_flags": {
      "type": "object",
      "properties": {
        "requires_escalation": { "type": "boolean" },
        "has_open_policy_violations": { "type": "boolean" },
        "has_active_waiver": { "type": "boolean" },
        "is_in_remediation": { "type": "boolean" }
      }
    },
    "policy_violations_active": {
      "type": "array",
      "items": { "$ref": "#/definitions/PolicyViolationRef" }
    },
    "checkpoint_refs": {
      "type": "array",
      "items": { "$ref": "#/definitions/CheckpointRef" }
    }
  },
  "definitions": {
    "ActorRecord": {
      "type": "object",
      "required": ["actor_id", "role"],
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" },
        "display_name": { "type": "string" },
        "delegation_chain": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "PolicyContextRef": {
      "type": "object",
      "properties": {
        "policy_mode": { "type": "string" },
        "environment": { "type": "string" },
        "domain": { "type": "string" },
        "active_policy_pack_id": { "type": "string" }
      }
    },
    "CompletedStageEntry": {
      "type": "object",
      "required": ["stage_name", "completed_at"],
      "properties": {
        "stage_name": { "type": "string" },
        "completed_at": { "type": "string", "format": "date-time" },
        "actor": { "$ref": "#/definitions/ActorRecord" },
        "audit_ref": { "type": "string" },
        "event_ref": { "type": "string" }
      }
    },
    "PendingReviewRef": {
      "type": "object",
      "required": ["review_id", "review_type", "stage_name"],
      "properties": {
        "review_id": { "type": "string" },
        "review_type": { "type": "string" },
        "stage_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "sla_due_at": { "type": "string", "format": "date-time" }
      }
    },
    "BlockingReason": {
      "type": "object",
      "required": ["reason_code", "description"],
      "properties": {
        "reason_code": { "type": "string" },
        "description": { "type": "string" },
        "blocking_since": { "type": "string", "format": "date-time" },
        "resolution_path": { "type": "string" }
      }
    },
    "ApprovalRef": {
      "type": "object",
      "required": ["audit_id", "approver_id", "approved_at"],
      "properties": {
        "audit_id": { "type": "string" },
        "approver_id": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" },
        "conditions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "PolicyViolationRef": {
      "type": "object",
      "required": ["violation_id", "rule_ref", "severity"],
      "properties": {
        "violation_id": { "type": "string" },
        "rule_ref": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "detected_at": { "type": "string", "format": "date-time" },
        "waiver_id": { "type": "string" }
      }
    },
    "CheckpointRef": {
      "type": "object",
      "required": ["checkpoint_id", "stage_name", "created_at"],
      "properties": {
        "checkpoint_id": { "type": "string" },
        "stage_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "storage_uri": { "type": "string" }
      }
    }
  }
}
