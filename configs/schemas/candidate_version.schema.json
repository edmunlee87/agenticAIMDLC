{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "candidate_version.schema.json",
  "title": "CandidateVersion",
  "description": "A versioned snapshot of a model or methodology produced at a build/train stage. Carries full provenance for auditability and selection.",
  "type": "object",
  "required": ["candidate_version_id", "project_id", "run_id", "session_id", "stage_name", "actor", "timestamp", "schema_version", "candidate_type", "artifact_refs"],
  "additionalProperties": false,
  "properties": {
    "candidate_version_id": { "type": "string" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "session_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "actor": { "$ref": "#/definitions/ActorRecord" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage_name": { "type": "string" },
    "policy_context": { "$ref": "#/definitions/PolicyContextRef" },
    "schema_version": { "type": "string", "default": "1.0.0" },
    "candidate_type": {
      "type": "string",
      "enum": ["model", "feature_set", "bin_definition", "threshold_set", "methodology_snapshot", "parameter_set"]
    },
    "parent_candidate_version_id": { "type": "string" },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "ready_for_review", "approved", "rejected", "superseded"]
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type"],
        "properties": {
          "artifact_id": { "type": "string" },
          "artifact_type": { "type": "string" },
          "uri": { "type": "string" },
          "checksum": { "type": "string" }
        }
      }
    },
    "parameters": {
      "type": "object",
      "description": "Key model/methodology parameters for this candidate.",
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "description": "Summary metrics for comparison (e.g., gini, ks, auc).",
      "additionalProperties": { "type": "number" }
    },
    "comparison_delta": {
      "type": "object",
      "description": "Delta vs. selected incumbent candidate version.",
      "additionalProperties": true
    },
    "policy_findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/PolicyFindingRef" }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "feature_set_ref": { "type": "string" },
        "dataset_snapshot_ref": { "type": "string" },
        "skill_version": { "type": "string" },
        "tool_versions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "ActorRecord": {
      "type": "object",
      "required": ["actor_id", "role"],
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" },
        "display_name": { "type": "string" },
        "delegation_chain": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PolicyContextRef": {
      "type": "object",
      "properties": {
        "policy_mode": { "type": "string" },
        "environment": { "type": "string" },
        "domain": { "type": "string" },
        "active_policy_pack_id": { "type": "string" }
      }
    },
    "PolicyFindingRef": {
      "type": "object",
      "required": ["finding_id", "severity", "rule_ref"],
      "properties": {
        "finding_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "rule_ref": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
