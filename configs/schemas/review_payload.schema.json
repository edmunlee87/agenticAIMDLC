{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "review_payload.schema.json",
  "title": "ReviewPayload",
  "description": "Structured payload presented to a human reviewer at a governance gate. Contains proposal, evidence, allowed actions, and governance requirements.",
  "type": "object",
  "required": ["review_id", "project_id", "run_id", "session_id", "stage_name", "review_type", "actor", "timestamp", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "review_id": { "type": "string" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "session_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "actor": { "$ref": "#/definitions/ActorRecord" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage_name": { "type": "string" },
    "policy_context": { "$ref": "#/definitions/PolicyContextRef" },
    "schema_version": { "type": "string", "default": "1.0.0" },
    "review_type": { "type": "string" },
    "title": { "type": "string" },
    "decision_required": { "type": "boolean", "default": true },
    "proposal_summary": {
      "type": "object",
      "properties": {
        "business_summary": { "type": "string" },
        "technical_summary": { "type": "string" },
        "recommendation": { "type": "string" },
        "alternatives": { "type": "array", "items": { "type": "string" } },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              "category": { "type": "string" },
              "description": { "type": "string" },
              "evidence_ref": { "type": "string" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type"],
        "properties": {
          "artifact_id": { "type": "string" },
          "artifact_type": { "type": "string" },
          "label": { "type": "string" },
          "uri": { "type": "string" }
        }
      }
    },
    "allowed_actions": {
      "type": "array",
      "description": "Exhaustive list of permitted actions for this review. Free-text alone is never approval.",
      "items": { "type": "string" }
    },
    "structured_edit_schema": {
      "type": "object",
      "description": "JSON schema describing the structured edits permitted for Panel B.",
      "additionalProperties": true
    },
    "policy_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "severity", "rule_ref"],
        "properties": {
          "finding_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "rule_ref": { "type": "string" },
          "description": { "type": "string" },
          "evidence_ref": { "type": "string" }
        }
      }
    },
    "linked_refs": {
      "type": "object",
      "description": "Cross-references to prior reviews, candidate versions, run context.",
      "additionalProperties": { "type": "string" }
    },
    "timestamps": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "stage_started_at": { "type": "string", "format": "date-time" }
      }
    },
    "governance_requirements": {
      "type": "object",
      "description": "Mandatory governance conditions for this review.",
      "properties": {
        "required_evidence": { "type": "array", "items": { "type": "string" } },
        "required_acknowledgments": { "type": "array", "items": { "type": "string" } },
        "sla_deadline": { "type": "string", "format": "date-time" },
        "minimum_approval_authority": { "type": "string" }
      }
    }
  },
  "definitions": {
    "ActorRecord": {
      "type": "object",
      "required": ["actor_id", "role"],
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" },
        "display_name": { "type": "string" },
        "delegation_chain": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PolicyContextRef": {
      "type": "object",
      "properties": {
        "policy_mode": { "type": "string" },
        "environment": { "type": "string" },
        "domain": { "type": "string" },
        "active_policy_pack_id": { "type": "string" }
      }
    }
  }
}
