{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "runtime_context.schema.json",
  "title": "RuntimeContext",
  "description": "Input to the runtime resolver. Captures the full execution context for a given controller invocation. Enriched with governance fields per enhancement v0.3.",
  "type": "object",
  "required": ["project_id", "run_id", "session_id", "active_role", "active_domain", "stage_name", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "session_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "actor": { "$ref": "#/definitions/ActorRecord" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage_name": { "type": "string" },
    "policy_context": { "$ref": "#/definitions/PolicyContextRef" },
    "schema_version": { "type": "string", "default": "1.0.0" },
    "active_role": { "type": "string" },
    "active_domain": { "type": "string" },
    "workflow_mode": {
      "type": "string",
      "enum": ["development", "validation", "monitoring", "annual_review", "remediation", "generic"]
    },
    "validation_mode": { "type": "boolean", "default": false },
    "annual_review_mode": { "type": "boolean", "default": false },
    "remediation_mode": { "type": "boolean", "default": false },
    "policy_mode": { "type": "string" },
    "pending_review_type": { "type": "string" },
    "ui_entry_point": { "type": "string" },
    "selected_candidate_version_id": { "type": "string" },
    "candidate_versions_present": { "type": "boolean", "default": false },
    "failure_state": { "type": "string" },
    "active_overlays": {
      "type": "array",
      "items": { "type": "string" }
    },
    "current_refs": {
      "type": "object",
      "description": "Stage-specific artifact/review/candidate refs currently in scope.",
      "additionalProperties": { "type": "string" }
    },
    "token_mode": {
      "type": "string",
      "enum": ["micro", "standard", "deep_review"]
    },
    "governance_flags": {
      "type": "object",
      "properties": {
        "requires_escalation": { "type": "boolean" },
        "has_open_policy_violations": { "type": "boolean" },
        "has_active_waiver": { "type": "boolean" },
        "is_in_remediation": { "type": "boolean" }
      }
    },
    "active_policy_violations": {
      "type": "array",
      "items": { "$ref": "#/definitions/PolicyViolationRef" }
    },
    "pending_remediation_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "delegation_context": {
      "type": "object",
      "properties": {
        "delegated_by": { "type": "string" },
        "delegation_reason": { "type": "string" },
        "delegation_expiry": { "type": "string", "format": "date-time" }
      }
    }
  },
  "definitions": {
    "ActorRecord": {
      "type": "object",
      "required": ["actor_id", "role"],
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" },
        "display_name": { "type": "string" },
        "delegation_chain": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PolicyContextRef": {
      "type": "object",
      "properties": {
        "policy_mode": { "type": "string" },
        "environment": { "type": "string" },
        "domain": { "type": "string" },
        "active_policy_pack_id": { "type": "string" }
      }
    },
    "PolicyViolationRef": {
      "type": "object",
      "required": ["violation_id", "rule_ref", "severity"],
      "properties": {
        "violation_id": { "type": "string" },
        "rule_ref": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "detected_at": { "type": "string", "format": "date-time" },
        "waiver_id": { "type": "string" }
      }
    }
  }
}
