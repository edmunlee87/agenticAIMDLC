{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "flow_edge.schema.json",
  "title": "FlowEdge",
  "description": "Directed edge between flow nodes for workflow visualization and lineage tracing.",
  "type": "object",
  "required": ["edge_id", "edge_type", "source_node_id", "target_node_id", "run_id", "project_id", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "edge_id": { "type": "string" },
    "edge_type": {
      "type": "string",
      "enum": ["depends_on", "produces_input_for", "approval_gate_to", "triggers", "recovers_to"]
    },
    "source_node_id": { "type": "string" },
    "target_node_id": { "type": "string" },
    "label": { "type": "string" },
    "run_id": { "type": "string" },
    "project_id": { "type": "string" },
    "session_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "actor": { "$ref": "#/definitions/ActorRecord" },
    "timestamp": { "type": "string", "format": "date-time" },
    "policy_context": { "$ref": "#/definitions/PolicyContextRef" },
    "schema_version": { "type": "string", "default": "1.0.0" },
    "source_event_id": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "definitions": {
    "ActorRecord": {
      "type": "object",
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "PolicyContextRef": {
      "type": "object",
      "properties": {
        "policy_mode": { "type": "string" },
        "environment": { "type": "string" },
        "domain": { "type": "string" }
      }
    }
  }
}
